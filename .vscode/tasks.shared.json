{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "lint",
      "type": "shell",
      "command": "pnpm lint",
      "problemMatcher": ["$eslint-stylish"],
      "icon": {
        "id": "check",
        "color": "terminal.ansiYellow"
      }
    },
    {
      "label": "lint:fix",
      "type": "shell",
      "command": "pnpm lint:fix --format=stylish",
      "problemMatcher": ["$eslint-stylish"],
      "icon": {
        "id": "check-all",
        "color": "terminal.ansiYellow"
      }
    },
    {
      "label": "format",
      "type": "npm",
      "script": "format",
      "icon": {
        "id": "paintcan",
        "color": "terminal.ansiBlue"
      },
      "problemMatcher": []
    },
    {
      "label": "dev",
      "icon": { "id": "browser", "color": "terminal.ansiCyan" },
      "type": "shell",
      "command": "pnpm run dev",
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "fileLocation": ["relative", "${workspaceFolder}/client"],
        "pattern": {
          "regexp": "^\\s*(.*):(\\d+):(\\d+):\\s+(error|warning):\\s+(.*)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "message": 5
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*VITE.*ready in",
          "endsPattern": "^.*Local:\\s+http://localhost"
        }
      },
      "presentation": {
        "echo": false,
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "runOptions": {
        "instanceLimit": 1,
        "instancePolicy": "terminateOldest",
        "reevaluateOnRerun": true
      }
    }
  ]
}
