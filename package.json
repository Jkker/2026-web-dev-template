{
  "name": "react-2026-template",
  "private": true,
  "type": "module",
  "imports": {
    "#*": [
      "./*",
      "./*.ts",
      "./*.tsx",
      "./*.js",
      "./*.jsx"
    ]
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "oxlint --type-aware --type-check",
    "lint:fix": "oxlint --type-aware --type-check --fix --fix-suggestions --fix-dangerously",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "postinstall": "simple-git-hooks && playwright install chromium"
  },
  "dependencies": {
    "@base-ui/react": "catalog:ui",
    "@fontsource-variable/noto-sans": "catalog:styling",
    "@tailwindcss/vite": "catalog:styling",
    "@tanstack/react-form": "catalog:tanstack",
    "@tanstack/react-query": "catalog:tanstack",
    "@tanstack/react-router": "catalog:tanstack",
    "arkenv": "catalog:arktype",
    "arkregex": "catalog:arktype",
    "arktype": "catalog:arktype",
    "class-variance-authority": "catalog:styling",
    "clsx": "catalog:styling",
    "es-toolkit": "catalog:runtime",
    "i18next": "catalog:i18n",
    "i18next-browser-languagedetector": "catalog:i18n",
    "i18next-http-backend": "catalog:i18n",
    "lucide-react": "catalog:ui",
    "react": "catalog:react",
    "react-dom": "catalog:react",
    "react-i18next": "catalog:i18n",
    "tailwind-merge": "catalog:styling",
    "tailwindcss": "catalog:styling",
    "temporal-polyfill": "catalog:runtime",
    "tw-animate-css": "catalog:styling",
    "vaul": "catalog:ui",
    "zustand": "catalog:runtime",
    "zustand-x": "catalog:runtime"
  },
  "devDependencies": {
    "@arkenv/vite-plugin": "catalog:arktype",
    "@commitlint/cli": "catalog:quality",
    "@commitlint/config-conventional": "catalog:quality",
    "@storybook/addon-a11y": "catalog:storybook",
    "@storybook/addon-docs": "catalog:storybook",
    "@storybook/addon-themes": "catalog:storybook",
    "@storybook/react-vite": "catalog:storybook",
    "@tanstack/devtools-vite": "catalog:devtools",
    "@tanstack/react-devtools": "catalog:devtools",
    "@tanstack/react-form-devtools": "catalog:devtools",
    "@tanstack/react-query-devtools": "catalog:devtools",
    "@tanstack/react-router-devtools": "catalog:devtools",
    "@tanstack/router-plugin": "catalog:tanstack",
    "@total-typescript/ts-reset": "catalog:typescript",
    "@types/node": "catalog:typescript",
    "@types/react": "catalog:typescript",
    "@types/react-dom": "catalog:typescript",
    "@typescript/native-preview": "catalog:typescript",
    "@vitejs/plugin-react": "catalog:build",
    "@vitest/browser-playwright": "catalog:testing",
    "@vitest/coverage-v8": "catalog:testing",
    "@vitest/ui": "catalog:testing",
    "babel-plugin-react-compiler": "catalog:build",
    "eslint-plugin-react-hooks": "catalog:quality",
    "knip": "catalog:quality",
    "lint-staged": "catalog:quality",
    "msw-storybook-addon": "catalog:storybook",
    "oxfmt": "catalog:quality",
    "oxlint": "catalog:quality",
    "oxlint-tsgolint": "catalog:quality",
    "playwright": "catalog:testing",
    "remark-gfm": "catalog:storybook",
    "shadcn": "catalog:ui",
    "simple-git-hooks": "catalog:quality",
    "storybook": "catalog:storybook",
    "typescript": "catalog:typescript",
    "vite": "catalog:build",
    "vitest": "catalog:testing",
    "vitest-browser-react": "catalog:testing",
    "zx": "catalog:build"
  },
  "simple-git-hooks": {
    "pre-commit": "lint-staged --relative",
    "commit-msg": "pnpm commitlint --edit $1"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx}": [
      "pnpm lint:fix",
      "pnpm format",
      "vitest related --run"
    ],
    "*.{json,md,css,html,yml,yaml}": [
      "pnpm format"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "onFail": "ignore",
      "version": "^10"
    },
    "runtime": {
      "name": "node",
      "onFail": "error",
      "version": "^24"
    }
  }
}
